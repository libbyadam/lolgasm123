# Copy this file to .env.local and fill in your Supabase project details.
# These values are safe to expose to the browser (the anon key is public by design),
# but row-level security policies on the `votes` table should restrict what it can do.

NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# The passcode required to access the survey.
NEXT_PUBLIC_SURVEY_PASSCODE=libbyisthebest
